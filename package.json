{
  "name": "practice-ide",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "typecheck": "tsc -p server --noEmit && tsc -p client --noEmit",
    "build": "npm run build -w client"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "typescript": "^7.0.2"
  }
}
